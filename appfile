import React, { useState, useEffect } from 'react';
import { initializeApp } from 'firebase/app';
import { getAuth, signInAnonymously, signInWithCustomToken, onAuthStateChanged } from 'firebase/auth';
import { getFirestore, collection, addDoc, onSnapshot } from 'firebase/firestore';
import { Camera, RefreshCcw, Sparkles, ShoppingBag, CheckCircle2, AlertCircle, ChevronRight, ExternalLink, Lightbulb, History, ArrowLeft } from 'lucide-react';

// --- Конфігурація Firebase (використовує змінні середовища) ---
const firebaseConfig = JSON.parse(__firebase_config);
const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getFirestore(app);
const appId = typeof __app_id !== 'undefined' ? __app_id : 'hillary-skin-care-app';

// --- База товарів HiLLARY (інтегровано з вашого JSON) ---
const HILLARY_DATABASE = [
  { 
    id: "HI-08-720", 
    name: "Сироватка-автозасмага Hillary Self Tan Serum", 
    category: "Сонцезахист", 
    description: "Надає шкірі природного відтінку засмаги та здорового сяйва. Містить компоненти для зволоження.",
    link: "https://hillary.ua/syrovatka-avtozasmaha-dlia-oblychchia-hillary-self-tan-serum-30-ml" 
  },
  { 
    id: "HI-08-111", 
    name: "Очищуюча пінка Vitis Vinifera", 
    category: "Очищення", 
    description: "Для сухої та чутливої шкіри. Ніжно очищує, не пересушуючи, заспокоює подразнення.",
    link: "https://hillary.ua/pinka-dlya-umyvannya-dlya-suhoyi-ta-chutlivoyi-shkiry-hillary-cleansing-foam-vitis-vinifera-skin-care-150-ml/" 
  },
  { 
    id: "HI-08-112", 
    name: "Очищуюча пінка Sulfate-free", 
    category: "Очищення", 
    description: "Для жирної та комбінованої шкіри. Глибоко очищує пори, регулює вироблення себуму та матує.",
    link: "https://hillary.ua/pinka-dlya-umyvannya-dlya-zhyrnoyi-ta-kombinovanoyi-shkiry-hillary-cleansing-foam-sulfate-free-150-ml/" 
  },
  { 
    id: "HI-08-721", 
    name: "Убтан для м'якого очищення Hillary Ubtan", 
    category: "Очищення", 
    description: "100% натуральний засіб. Видаляє чорні цятки, звужує пори та вирівнює колір обличчя.",
    link: "https://hillary.ua/ubtan-dlya-myakogo-ochyshchennya-ta-skrabuvannya-hillary-ubtan-75-g/" 
  },
  { 
    id: "HI-08-654", 
    name: "Сироватка з вітаміном С Hillary Vitamin C Serum", 
    category: "Сироватки", 
    description: "Освітлює пігментацію, вирівнює тон шкіри та стимулює синтез колагену.",
    link: "https://hillary.ua/syrovatka-dlya-oblychchya-z-vitaminom-c-hillary-vitamin-c-serum-30-ml/" 
  },
  { 
    id: "HI-08-332", 
    name: "Крем з гіалуроновою кислотою Hyaluronic Cream", 
    category: "Зволоження", 
    description: "Відновлює захисний бар'єр, інтенсивно зволожує та утримує вологу.",
    link: "https://hillary.ua/krem-dlya-oblychchya-z-gialuronovoyu-kyslotoyu-hillary-hyaluronic-cream-50-ml/" 
  },
  { 
    id: "HI-08-990", 
    name: "Мультикомплексна сироватка з ретинолом Hillary Bakuchiol", 
    category: "Сироватки", 
    description: "Антивіковий догляд. Бореться зі зморшками та покращує пружність шкіри.",
    link: "https://hillary.ua/multykompleksna-syrovatka-z-retynolom-hillary-bakuchiol-retinol-serum-30-ml/" 
  },
  { 
    id: "HI-08-105", 
    name: "Гідрофільна олія Cleansing Oil", 
    category: "Очищення", 
    description: "Ефективно розчиняє макіяж та сонцезахисні засоби, не забиваючи пори.",
    link: "https://hillary.ua/gidrofilna-oliya-dlya-vmyvannya-hillary-cleansing-oil-150-ml/" 
  },
  { 
    id: "HI-08-120", 
    name: "Тонік для жирної та комбінованої шкіри", 
    category: "Тонізація", 
    description: "Завершує процес очищення, балансує pH шкіри та матує.",
    link: "https://hillary.ua/tonik-dlya-zhyrnoyi-ta-kombinovanoyi-shkiry-hillary-toner-moisturizing-skin-care-200-ml/" 
  },
  { 
    id: "HI-08-655", 
    name: "Крем-флюїд з вітаміном С Vitamin C Fluid", 
    category: "Зволоження", 
    description: "Легкий зволожуючий крем для надання здорового сяйва та захисту.",
    link: "https://hillary.ua/krem-flyuyid-dlya-oblychchya-z-vitaminom-c-hillary-vitamin-c-fluid-cream-30-ml/" 
  }
];

export default function App() {
  const [user, setUser] = useState(null);
  const [step, setStep] = useState('welcome');
  const [image, setImage] = useState(null);
  const [base64Image, setBase64Image] = useState(null);
  const [userData, setUserData] = useState({ age: '', skinType: 'не знаю', concerns: '' });
  const [analysis, setAnalysis] = useState(null);
  const [recommendations, setRecommendations] = useState([]);
  const [pastAnalyses, setPastAnalyses] = useState([]);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState(null);
  const apiKey = ""; 

  // --- Telegram SDK & Auth ---
  useEffect(() => {
    // Ініціалізація Telegram WebApp
    if (window.Telegram && window.Telegram.WebApp) {
      const tg = window.Telegram.WebApp;
      tg.ready();
      tg.expand();
    }

    const initAuth = async () => {
      if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
        await signInWithCustomToken(auth, __initial_auth_token);
      } else {
        await signInAnonymously(auth);
      }
    };
    initAuth();
    const unsubscribe = onAuthStateChanged(auth, setUser);
    return () => unsubscribe();
  }, []);

  // --- Завантаження історії з Firestore ---
  useEffect(() => {
    if (!user) return;
    const historyRef = collection(db, 'artifacts', appId, 'users', user.uid, 'history');
    const unsubscribe = onSnapshot(historyRef, (snapshot) => {
      const items = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
      setPastAnalyses(items.sort((a, b) => new Date(b.date) - new Date(a.date)));
    }, (err) => console.error("Firestore error:", err));
    return () => unsubscribe();
  }, [user]);

  // --- Обробка зображення ---
  const handleImageChange = (e) => {
    const file = e.target.files[0];
    if (file) {
      const reader = new FileReader();
      reader.onloadend = () => {
        setImage(URL.createObjectURL(file));
        setBase64Image(reader.result.split(',')[1]);
        setStep('questions');
      };
      reader.readAsDataURL(file);
    }
  };

  // --- Аналіз через Gemini API ---
  const performAnalysis = async () => {
    setLoading(true);
    setStep('analyzing');
    setError(null);

    const catalogContext = HILLARY_DATABASE.map(p => 
      `Арт: ${p.id}, Назва: ${p.name}, Призначення: ${p.description}`
    ).join('\n---\n');

    const systemPrompt = `Ти - професійний ШІ-косметолог HiLLARY Cosmetics.
    ТВОЇ ПРАВИЛА:
    1. ВАЛІДАЦІЯ: Якщо на фото не обличчя людини (тварина, об'єкт, малюнок) - rejection_reason.
    2. АНАЛІЗ: Проаналізуй фото на пори, тон, зморшки, висипи.
    3. РЕКОМЕНДАЦІЯ: Підбери 3-4 засоби ТІЛЬКИ з наданого списку.
    4. ЗАБОРОНА: У полях "skin_condition" та "advice" НЕ ПИШИ артикули (ID). Тільки назви.
    
    КАТАЛОГ:
    ${catalogContext}

    ВІДПОВІДЬ (JSON):
    {
      "is_human_face": true/false,
      "rejection_reason": "чому не підходить фото",
      "skin_type": "визначений тип",
      "skin_condition": "діагноз українською без артикулів",
      "suggested_ids": ["масив Артикулів (ID)"],
      "advice": "порада без артикулів"
    }`;

    try {
      const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          contents: [{
            role: "user",
            parts: [
              { text: `Вік: ${userData.age}, Тип: ${userData.skinType}, Скарги: ${userData.concerns}. Проаналізуй фото та підбери догляд Hillary.` },
              { inlineData: { mimeType: "image/png", data: base64Image } }
            ]
          }],
          systemInstruction: { parts: [{ text: systemPrompt }] },
          generationConfig: { responseMimeType: "application/json" }
        })
      });

      const result = await response.json();
      const text = result.candidates[0].content.parts[0].text;
      const parsedData = JSON.parse(text);
      
      if (!parsedData.is_human_face) {
        setError(parsedData.rejection_reason || "Ми не змогли розпізнати обличчя.");
        setStep('upload');
        return;
      }

      setAnalysis(parsedData);
      const filteredRecs = HILLARY_DATABASE.filter(p => parsedData.suggested_ids.includes(p.id));
      setRecommendations(filteredRecs);
      
      if (user) {
        await addDoc(collection(db, 'artifacts', appId, 'users', user.uid, 'history'), {
          date: new Date().toISOString(),
          analysis: parsedData,
          recommendationIds: filteredRecs.map(r => r.id),
          userPhoto: image
        });
      }
      
      setStep('results');
    } catch (err) {
      setError("Помилка аналізу. Спробуйте ще раз.");
      setStep('questions');
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="min-h-screen bg-white font-sans text-slate-900 max-w-md mx-auto shadow-2xl relative flex flex-col overflow-hidden">
      <header className="sticky top-0 bg-white/90 backdrop-blur-md z-50 px-6 py-4 border-b border-slate-100 flex items-center justify-between shrink-0">
        <div className="flex items-center gap-2 cursor-pointer" onClick={() => setStep('welcome')}>
          <div className="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center -rotate-2">
            <span className="text-white font-black text-sm">H</span>
          </div>
          <span className="font-bold text-lg tracking-tight">HiLLARY AI</span>
        </div>
        <button onClick={() => setStep('history')} className="p-2 hover:bg-slate-50 rounded-full">
          <History className="w-5 h-5 text-slate-400" />
        </button>
      </header>

      <main className="flex-1 overflow-y-auto">
        {step === 'welcome' && (
          <div className="flex flex-col items-center justify-center min-h-[80vh] p-8 text-center animate-in fade-in duration-700">
            <div className="w-24 h-24 bg-blue-50 rounded-full flex items-center justify-center mb-8 shadow-sm">
              <Sparkles className="w-12 h-12 text-blue-500" />
            </div>
            <h1 className="text-3xl font-bold text-slate-800 mb-4">Твій персональний догляд</h1>
            <p className="text-slate-500 mb-10 leading-relaxed">Ми проаналізуємо стан твоєї шкіри та підберемо ідеальну лінійку HiLLARY.</p>
            <button onClick={() => setStep('upload')} className="w-full bg-blue-600 text-white py-5 rounded-2xl font-bold text-lg shadow-xl active:scale-95 transition-all">Почати</button>
          </div>
        )}

        {step === 'upload' && (
          <div className="p-6">
            <h2 className="text-2xl font-bold mb-2">Крок 1: Фото</h2>
            <p className="text-slate-500 mb-8 font-medium">Для точного аналізу зробіть чітке селфі при денному світлі.</p>
            <div className="border-2 border-dashed border-slate-200 rounded-[2rem] p-16 flex flex-col items-center justify-center bg-slate-50/50 hover:border-blue-400 transition-all">
              <input type="file" accept="image/*" onChange={handleImageChange} className="hidden" id="cam-input" />
              <label htmlFor="cam-input" className="cursor-pointer flex flex-col items-center">
                <div className="w-16 h-16 bg-white rounded-full flex items-center justify-center mb-4 shadow-sm"><Camera className="text-blue-500 w-8 h-8" /></div>
                <span className="font-bold text-slate-700">Зробити селфі</span>
              </label>
            </div>
            {error && <div className="mt-4 p-4 bg-red-50 text-red-600 rounded-2xl text-xs font-bold flex gap-2"><AlertCircle className="w-4 h-4 shrink-0"/>{error}</div>}
          </div>
        )}

        {step === 'questions' && (
          <div className="p-6 animate-in slide-in-from-right-10">
            <h2 className="text-2xl font-bold mb-6">Крок 2: Деталі</h2>
            <div className="space-y-6">
              <div>
                <label className="text-[10px] font-black uppercase tracking-widest text-slate-400 ml-1 block mb-2">Твій вік</label>
                <input 
                  type="number" 
                  value={userData.age}
                  placeholder="25"
                  className="w-full p-4 rounded-xl border border-slate-200 focus:border-blue-500 outline-none font-bold"
                  onChange={(e) => setUserData({...userData, age: e.target.value})}
                />
              </div>
              <div>
                <label className="text-[10px] font-black uppercase tracking-widest text-slate-400 ml-1 block mb-2">Тип шкіри</label>
                <div className="grid grid-cols-2 gap-2">
                  {['Суха', 'Жирна', 'Комбінована', 'Не знаю'].map(t => (
                    <button key={t} onClick={() => setUserData({...userData, skinType: t})} className={`p-3 rounded-xl border-2 font-bold text-xs transition-all ${userData.skinType === t ? 'border-blue-600 bg-blue-50 text-blue-600' : 'border-slate-100 text-slate-500'}`}>{t}</button>
                  ))}
                </div>
              </div>
              <div>
                <label className="text-[10px] font-black uppercase tracking-widest text-slate-400 ml-1 block mb-2">Що тебе турбує?</label>
                <textarea 
                  value={userData.concerns}
                  placeholder="Тьмяність, висипи, сухість..."
                  className="w-full p-4 rounded-xl border border-slate-200 focus:border-blue-500 outline-none h-28 resize-none text-sm font-medium leading-relaxed"
                  onChange={(e) => setUserData({...userData, concerns: e.target.value})}
                />
              </div>
              <button onClick={performAnalysis} disabled={!userData.age || loading} className="w-full bg-blue-600 text-white py-5 rounded-2xl font-bold shadow-xl active:scale-95 transition-all">Отримати рекомендації</button>
            </div>
          </div>
        )}

        {step === 'analyzing' && (
          <div className="flex flex-col items-center justify-center min-h-[80vh] p-8 text-center">
            <RefreshCcw className="w-12 h-12 text-blue-600 animate-spin mb-6"/>
            <h3 className="text-xl font-bold">Створюємо твою програму...</h3>
            <p className="text-slate-400 text-sm mt-2 leading-relaxed">ШІ вивчає твоє фото та асортимент HiLLARY Cosmetics</p>
          </div>
        )}

        {step === 'results' && (
          <div className="pb-12 animate-in fade-in">
            <div className="h-56 relative">
              <img src={image} className="w-full h-full object-cover" />
              <div className="absolute inset-0 bg-gradient-to-t from-white via-transparent"></div>
              <button onClick={() => setStep('upload')} className="absolute top-4 right-4 bg-white/80 p-3 rounded-full shadow-lg"><RefreshCcw className="w-5 h-5 text-slate-700" /></button>
            </div>
            <div className="px-6 -mt-10 relative z-10">
              <div className="bg-white rounded-[2rem] p-6 shadow-2xl border border-slate-50 mb-8">
                <h3 className="font-bold text-lg mb-4 flex items-center gap-2 text-slate-800"><CheckCircle2 className="text-green-500 w-5 h-5"/> Результати аналізу</h3>
                <p className="text-slate-700 text-sm mb-6 leading-relaxed font-medium">{analysis?.skin_condition}</p>
                <div className="bg-blue-50 p-5 rounded-2xl flex items-start gap-3 border-l-4 border-blue-600 shadow-sm">
                  <Lightbulb className="w-5 h-5 text-blue-600 mt-1 shrink-0" />
                  <p className="text-blue-900 text-sm italic font-bold leading-relaxed">"{analysis?.advice}"</p>
                </div>
              </div>
              <h3 className="text-xl font-black text-slate-800 mb-6 flex items-center gap-2 px-2"><ShoppingBag className="w-6 h-6 text-blue-600" /> Твій догляд</h3>
              <div className="space-y-4">
                {recommendations.map(item => (
                  <div key={item.id} className="bg-white border border-slate-100 p-5 rounded-3xl shadow-sm hover:shadow-md transition-all">
                    <div className="flex items-start justify-between mb-3">
                      <span className="text-[9px] font-black text-slate-300 uppercase tracking-widest">Арт: {item.id}</span>
                      <a href={item.link} target="_blank" rel="noopener noreferrer" className="text-blue-500 p-2 bg-blue-50 rounded-xl hover:bg-blue-600 hover:text-white transition-all"><ExternalLink className="w-4 h-4" /></a>
                    </div>
                    <h4 className="font-black text-slate-800 text-md leading-tight mb-2">{item.name}</h4>
                    <p className="text-slate-500 text-xs leading-relaxed mb-4 font-medium">{item.description}</p>
                    <a href={item.link} target="_blank" rel="noopener noreferrer" className="inline-flex items-center gap-1 text-blue-600 text-xs font-black uppercase tracking-widest">Замовити на сайті <ChevronRight className="w-4 h-4" /></a>
                  </div>
                ))}
              </div>
              <button onClick={() => setStep('welcome')} className="w-full mt-12 py-5 text-slate-300 font-black uppercase tracking-widest text-[10px]">Новий аналіз</button>
            </div>
          </div>
        )}

        {step === 'history' && (
          <div className="p-6">
            <button onClick={() => setStep('welcome')} className="mb-6 flex items-center gap-2 text-slate-400 font-black text-[10px] uppercase tracking-widest"><ArrowLeft className="w-4 h-4"/> Назад</button>
            <h2 className="text-2xl font-black mb-8">Історія</h2>
            <div className="space-y-4">
              {pastAnalyses.length === 0 ? (
                <div className="text-center py-24 text-slate-300 font-bold italic">Тут поки порожньо</div>
              ) : (
                pastAnalyses.map(item => (
                  <div key={item.id} className="bg-white border border-slate-100 p-4 rounded-2xl shadow-sm flex items-center gap-4">
                    <img src={item.userPhoto} className="w-14 h-14 rounded-xl object-cover shadow-sm" />
                    <div className="flex-1">
                      <p className="text-[10px] text-slate-400 font-black uppercase">{new Date(item.date).toLocaleDateString()}</p>
                      <h4 className="font-bold text-slate-800 text-sm">{item.analysis.skin_type || 'Тип не вказано'}</h4>
                    </div>
                    <button onClick={() => { setAnalysis(item.analysis); setImage(item.userPhoto); setRecommendations(HILLARY_DATABASE.filter(p => item.recommendationIds.includes(p.id))); setStep('results'); }} className="text-blue-600 font-black text-[10px] uppercase tracking-tighter">Дивитись</button>
                  </div>
                ))
              )}
            </div>
          </div>
        )}
      </main>
    </div>
  );
}
